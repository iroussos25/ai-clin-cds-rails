<%# Recruiter Kit Panel %>
<div data-controller="recruiter-kit" class="space-y-6">
  <div data-recruiter-kits='<%= @recruiter_kits.map { |k| { title: k[:title], clinical_text: k[:clinical_text], prompts: k[:prompts] } }.to_json %>'></div>
  <div>
    <h2 class="text-2xl font-bold text-white">Recruiter Kit</h2>
    <p class="text-gray-400 text-sm mt-1">Pre-loaded clinical scenarios demonstrating AI analysis capabilities</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @recruiter_kits.each_with_index do |kit, index| %>
      <div class="bg-gray-900 rounded-xl border border-gray-800 p-5 hover:border-gray-700 transition-colors cursor-pointer group"
           data-action="click->recruiter-kit#loadKit"
           data-recruiter-kit-index-param="<%= index %>">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="text-white font-semibold group-hover:text-blue-400 transition-colors">
              <%= kit[:title] %>
            </h3>
            <p class="text-gray-500 text-sm mt-1"><%= kit[:summary] %></p>
          </div>
          <span class="text-xs px-2 py-1 bg-gray-800 text-gray-400 rounded-md"><%= kit[:category] %></span>
        </div>
        <div class="mt-3 text-xs text-gray-600">
          <%= kit[:note_length_label] %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Kit Preview/Analysis Section %>
  <div data-recruiter-kit-target="preview" class="hidden">
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 data-recruiter-kit-target="previewTitle" class="text-lg font-semibold text-white"></h3>
        <div class="flex gap-2">
          <button data-action="click->recruiter-kit#analyzeKit"
                  data-recruiter-kit-target="analyzeBtn"
                  class="px-3 py-1.5 text-sm bg-blue-600 hover:bg-blue-500 text-white rounded-lg transition-colors">
            Analyze with AI
          </button>
          <button data-action="click->recruiter-kit#closePreview"
                  class="px-3 py-1.5 text-sm bg-gray-800 text-gray-300 hover:bg-gray-700 rounded-lg transition-colors">
            Close
          </button>
        </div>
      </div>
      <div data-recruiter-kit-target="previewContent"
           class="prose prose-invert prose-sm max-w-none text-gray-400 max-h-96 overflow-y-auto whitespace-pre-wrap text-xs font-mono bg-gray-800/50 rounded-lg p-4"></div>
    </div>

    <%# Analysis Result %>
    <div data-recruiter-kit-target="result" class="hidden mt-4 bg-gray-900 rounded-xl border border-gray-800 p-5">
      <h3 class="text-sm font-semibold text-gray-300 mb-3">AI Analysis</h3>
      <div data-recruiter-kit-target="resultContent"
           class="prose prose-invert prose-sm max-w-none text-gray-300"></div>
    </div>
  </div>
</div>
