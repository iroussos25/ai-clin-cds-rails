<%# Clinical Review Panel %>
<div data-controller="clinical-review" class="space-y-6">
  <div>
    <h2 class="text-2xl font-bold text-white">Clinical Review</h2>
    <p class="text-gray-400 text-sm mt-1">Multi-turn clinical consultation with structured evidence synthesis</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Chat History %>
    <div class="lg:col-span-2 bg-gray-900 rounded-xl border border-gray-800 flex flex-col" style="height: 600px;">
      <div class="p-4 border-b border-gray-800 flex items-center justify-between">
        <h3 class="text-sm font-semibold text-gray-300">Consultation Thread</h3>
        <button data-action="click->clinical-review#clearHistory"
                class="text-xs text-gray-500 hover:text-red-400 transition-colors">
          Clear History
        </button>
      </div>

      <div data-clinical-review-target="messages" class="flex-1 overflow-y-auto p-4 space-y-4">
        <div class="flex items-center justify-center h-full text-gray-600 text-sm">
          <p class="text-center">
            Start a clinical consultation.<br>
            <span class="text-xs">Ask questions about clinical scenarios, differential diagnoses, or treatment plans.</span>
          </p>
        </div>
      </div>

      <div class="p-4 border-t border-gray-800">
        <div class="flex gap-3">
          <textarea
            data-clinical-review-target="input"
            data-action="keydown.enter->clinical-review#submitOnEnter"
            placeholder="Enter your clinical question..."
            rows="2"
            class="flex-1 bg-gray-800 border border-gray-700 rounded-lg p-3 text-sm text-gray-200 placeholder-gray-600 resize-none focus:outline-none focus:ring-2 focus:ring-blue-500/50"></textarea>
          <button data-action="click->clinical-review#submit"
                  data-clinical-review-target="submitBtn"
                  class="px-4 py-2 bg-blue-600 hover:bg-blue-500 disabled:bg-gray-700 text-white rounded-lg transition-colors self-end">
            Send
          </button>
        </div>
      </div>
    </div>

    <%# Evidence Sidebar %>
    <div class="space-y-4">
      <div class="bg-gray-900 rounded-xl border border-gray-800 p-4">
        <h3 class="text-sm font-semibold text-gray-300 mb-3">External Evidence</h3>
        <label class="inline-flex items-center gap-2 text-sm text-gray-400 cursor-pointer">
          <input type="checkbox" data-clinical-review-target="evidenceToggle"
                 class="rounded border-gray-600 bg-gray-700 text-blue-500 focus:ring-blue-500/50">
          <span>Include PubMed evidence</span>
        </label>
        <div data-clinical-review-target="evidencePanel" class="mt-3 space-y-2 text-xs text-gray-500"></div>
      </div>

      <div class="bg-gray-900 rounded-xl border border-gray-800 p-4">
        <h3 class="text-sm font-semibold text-gray-300 mb-3">Session Info</h3>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between">
            <dt class="text-gray-500">Messages</dt>
            <dd data-clinical-review-target="messageCount" class="text-gray-300">0</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Model</dt>
            <dd class="text-gray-300 text-xs">Gemini 2.5 Flash</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>
